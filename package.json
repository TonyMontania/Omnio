{
  "name": "Omnio",
  "private": true,
  "version": "0.2.3",
  "description": "Local-first desktop app to track your hobbies — games, music, movies, series, anime and comics — all in one place.",
  "author": "Omnio",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icon": "node scripts/build-icon.mjs",
    "build": "npm run icon && tsc && vite build && electron-builder --publish=never",
    "packaging:stamp": "node scripts/stamp-packaging.mjs",
    "packaging:check": "node scripts/stamp-packaging.mjs --check",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "allowScripts": {
    "electron@30.5.1": true,
    "esbuild@0.21.5": true
  }
}
