// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.omnio.app",
  "asar": true,
  "productName": "Omnio",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  // Copies the icon files next to the app so BrowserWindow.icon can resolve
  // them at runtime (the .ico embedded into the .exe by win.icon is separate
  // and drives the taskbar).
  "extraResources": [
    { "from": "build/icon.ico", "to": "icon.ico" },
    { "from": "build/icon.png", "to": "icon.png" }
  ],
  "mac": {
    "icon": "build/icon.png",
    // Build a universal binary that runs natively on Intel + Apple Silicon.
    // category is required by Apple for the .dmg installer.
    "category": "public.app-category.productivity",
    "target": [
      { "target": "dmg", "arch": ["x64", "arm64"] },
      { "target": "zip", "arch": ["x64", "arm64"] }
    ],
    "artifactName": "${productName}-Mac-${version}-${arch}.${ext}"
  },
  "win": {
    "icon": "build/icon.ico",
    "target": [
      { "target": "portable", "arch": ["x64"] },
      { "target": "nsis",     "arch": ["x64"] }
    ]
  },
  "portable": {
    "artifactName": "${productName}-${version}-portable.${ext}"
  },
  "nsis": {
    // Classic installer for users who want a Start Menu entry / uninstaller.
    // Note: NSIS installs writes data.json + assets/ under %APPDATA%\Omnio,
    // NOT next to the executable — use the portable build for USB-stick mode.
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "artifactName": "${productName}-${version}-setup.${ext}"
  },
  "linux": {
    "icon": "build/icon.png",
    "category": "Utility",
    // Required by fpm for the .deb target. Not a real address — just a
    // syntactically valid placeholder so the build succeeds. Swap for a real
    // one if/when you want Debian users to have a working contact.
    "maintainer": "Tony Montania <omnio@users.noreply.github.com>",
    "target": [
      "AppImage",
      "deb",
      "tar.gz"
    ],
    "artifactName": "${productName}-Linux-${version}.${ext}"
  }
}
